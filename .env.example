# Copy this file to .env and fill in your real Supabase project values.
# Find these in your Supabase project: Settings -> API
#
# VITE_SUPABASE_ANON_KEY is safe to expose in the browser bundle (it is the
# public anon key, not the secret service_role key). Access control is
# enforced server-side by the Row Level Security policies in
# supabase/schema.sql, not by hiding this key.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
